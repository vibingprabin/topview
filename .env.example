# TopView Environment Configuration
# Copy this file to .env and fill in your actual values

# Market Data API Configuration
MARKET_API_BASE_URL=https://api.example.com
API_TIMEOUT=15

# Market Data Scraping
MARKET_DATA_CACHE_DURATION=300
ENABLE_BACKGROUND_SYNC=true

# Notification Settings
ENABLE_NOTIFICATIONS=true
NOTIFICATION_CHECK_INTERVAL=300000

# Database Configuration
DB_VERSION=3
ENABLE_DB_LOGGING=false

# Feature Flags
ENABLE_STOP_LOSS_ALERTS=true
ENABLE_IPO_ALERTS=true
ENABLE_PRICE_ALERTS=true

# Cache Settings
CACHE_MAX_AGE_SECONDS=86400
CACHE_STALE_REVALIDATE=true
